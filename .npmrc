# vite-plugin-pwa@1.2.0 declares its Vite peer dep as `^3 || ^4 || ^5 || ^6 || ^7`,
# which is outdated — the plugin works fine against Vite 8 at runtime (it uses
# stable plugin APIs) but npm's strict peer resolver refuses to install.
# legacy-peer-deps lets install proceed without the bogus conflict.
#
# Drop this file once vite-plugin-pwa publishes a release with Vite 8 in the
# peer range. Until then, keeping install behaviour consistent between local
# dev, CI, and Vercel means everyone needs this flag.
legacy-peer-deps=true
